{
  "name": "scoop-news",
  "version": "1.0.0",
  "private": true,
  "main": "backend/server.js",
  "scripts": {
    "build": "npm ci --prefix backend && npm ci --prefix frontend && npm run build --prefix frontend",
    "start": "npm run start:web",
    "start:web": "ENABLE_SCHEDULER=false node backend/server.js",
    "start:scheduler": "node backend/src/jobs/schedulerProcess.js",
    "start:worker": "node backend/src/jobs/workerProcess.js",
    "dev:web": "npm run dev:web --prefix backend",
    "dev:scheduler": "npm run dev:scheduler --prefix backend",
    "dev:worker": "npm run dev:worker --prefix backend",
    "db:backup": "npm run db:backup --prefix backend"
  },
  "dependencies": {
    "express": "^4.18.2"
  }
}
