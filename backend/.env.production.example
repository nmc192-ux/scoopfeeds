NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# Optional, comma-separated. If Scoop serves the frontend itself, you usually
# do not need to set this unless a different origin will call the API directly.
ALLOWED_ORIGINS=

# Optional feature keys
OPENWEATHER_API_KEY=
GEMINI_API_KEY=

# ── LLM cost rails (2026-07-15 incident) ────────────────────────────────
# PIN the Gemini generation model explicitly — never a "-latest" floating
# alias. In July 2026 the alias silently resolved to a THINKING model whose
# reasoning tokens bill as OUTPUT; combined with key-presence provider
# fallback this burned ~$25/day producing nothing user-visible.
# gemini-2.5-flash rates (2026-07): $0.30 / 1M input, $2.50 / 1M output.
GEMINI_GENERATION_MODEL=gemini-2.5-flash
# Global hard ceiling on generation calls per UTC day, all tasks/providers.
# On breach, callers fall back to deterministic output until midnight.
LLM_DAILY_CALL_CAP=2000
# Explicit provider routing (gate b makes these REQUIRED; set them now if
# the keys exist — key-presence auto-detection is what allowed the drift):
#LLM_PROVIDER=cerebras
#LLM_PREMIUM_PROVIDER=groq
#EMBED_PROVIDER=cloudflare
REDIS_URL=
BULLMQ_PREFIX=scoop
USE_BULLMQ=true
REQUIRE_REDIS=true
QUEUE_CONCURRENCY_INGESTION=1
QUEUE_CONCURRENCY_VIDEO=1
QUEUE_CONCURRENCY_ENRICHMENT=2
