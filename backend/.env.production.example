NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# Optional, comma-separated. If Scoop serves the frontend itself, you usually
# do not need to set this unless a different origin will call the API directly.
ALLOWED_ORIGINS=

# Optional feature keys
OPENWEATHER_API_KEY=
GEMINI_API_KEY=
REDIS_URL=
BULLMQ_PREFIX=scoop
USE_BULLMQ=true
REQUIRE_REDIS=true
QUEUE_CONCURRENCY_INGESTION=1
QUEUE_CONCURRENCY_VIDEO=1
QUEUE_CONCURRENCY_ENRICHMENT=2
