PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001

# Primary production site on Hostinger.
PRIMARY_SITE_URL=https://scoopfeeds.com
# Old hostnames that should 301 redirect to the primary site.
REDIRECT_FROM_HOSTS=scoop.urbenofficial.com,www.scoop.urbenofficial.com
# ENABLE_SCHEDULER controls whether this process runs the event scheduler
#
# Two valid configurations:
#
# 1. Monolithic (single process runs everything):
#    ENABLE_SCHEDULER=true
#    Web process embeds the scheduler. Suitable for low-traffic deployments
#    and single-server hosting (e.g., Hostinger Node.js Web App).
#
# 2. Split (web + scheduler as separate processes):
#    web process: ENABLE_SCHEDULER=false (focuses on serving HTTP requests)
#    scheduler process: ENABLE_SCHEDULER=true (focuses on cron jobs)
#    Run the scheduler process: npm run start:scheduler (or directly:
#    node backend/src/jobs/schedulerProcess.js).
#    Suitable for higher-traffic deployments where the scheduler's cron work
#    competes with HTTP request handling for CPU/memory.
#
# Phase A default: monolithic (ENABLE_SCHEDULER=true on the single process)
# Phase E target: split (when traffic justifies separation)
#
# See also "Queue / Redis foundation" below for the 3-process variant with USE_BULLMQ.
# Set to false if you want to isolate startup/runtime issues on Hostinger.
ENABLE_SCHEDULER=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SLOW_API_THRESHOLD_MS=1000

# AdSense runtime config served by /api/public-config and /ads.txt
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX
ADSENSE_SLOT_BANNER=1234567890
ADSENSE_SLOT_SIDEBAR=1234567890
ADSENSE_SLOT_INLINE=1234567890
ADSENSE_TEST_MODE=true

# ── Web Push (Phase 2a) ─────────────────────────────────────────────────
# If both unset, the server auto-generates a VAPID keypair on first boot
# and persists it to backend/data/vapid.json. Setting these env vars
# overrides the on-disk file. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:hi@scoopfeeds.com
# Set to false to disable the breaking-news push trigger
ENABLE_BREAKING_PUSH=true
# Quiet hours when breaking-news pushes are suppressed (server local time)
PUSH_QUIET_START=22
PUSH_QUIET_END=7

# ── Email delivery (subscriber digest + X-posting digest) ───────────────
# SMTP powers both the daily subscriber digest (07:00 server time, services/
# digest.js) and the daily X-posting digest (09:00 UTC, services/xPostDigest.js
# — Phase B Sprint 2.x.2). Mailer skips all sends gracefully when any of
# SMTP_HOST/SMTP_USER/SMTP_PASS is unset (logs "SMTP not configured"; no
# error thrown). Inspect live state via /scoop-ops/newsletter/status (admin).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
NEWSLETTER_FROM=Scoop <no-reply@scoopfeeds.com>
# Single recipient for the daily X-posting digest. Unset = the 09:00 UTC
# X-digest cron skips entirely with no email sent.
DIGEST_RECIPIENT_EMAIL=

# ── Social auto-poster (Phase 2b) ───────────────────────────────────────
# Bluesky: create an "app password" at bsky.app/settings/app-passwords —
# do NOT use your account's main password. Without these set the auto-
# poster is a no-op (the rest of the app keeps working).
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
BLUESKY_PDS_URL=https://bsky.social
# Set to false to disable auto-posting site-wide without a code change
ENABLE_AUTO_SOCIAL=true

# ── Facebook Page auto-poster (Phase 2d) ───────────────────────────────
# Permanent page access token — does NOT expire if generated from a long-lived
# user token via GET /me/accounts. Setup steps:
#   1. developers.facebook.com → create app → add Pages API product
#   2. Graph API Explorer → generate User Token (pages_manage_posts, pages_read_engagement)
#   3. Exchange for long-lived: GET /oauth/access_token?grant_type=fb_exchange_token&...
#   4. GET /me/accounts?access_token={long-lived} → copy your page's `access_token`
# FACEBOOK_PAGE_ID is the numeric ID shown in your Page's About section.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# ── Threads auto-poster (Phase 2b+) ────────────────────────────────────
# Generate a long-lived user access token via the Meta developer console
# (Threads API → User Token Generator). Also set the numeric user-id shown
# on that same page, and the @handle without the @ sign.
# Without these set the Threads poster is a no-op.
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_HANDLE=

# ── Pinterest auto-poster (Phase B Track 1) ───────────────────────────
# Pinterest API v5 publisher. Pins resurface in Google for years (durable
# SEO value, unlike Twitter/Bluesky). Local OAuth flow:
#   1. developers.pinterest.com → create app "Scoopfeeds Autoposter"
#      → add redirect URI http://localhost:8088/callback
#   2. Connect Pinterest Business account to the app (Apps → Auth)
#   3. export PINTEREST_APP_ID + PINTEREST_APP_SECRET, then run
#      node backend/scripts/pinterest-auth.mjs — prints ACCESS_TOKEN,
#      REFRESH_TOKEN, and lists boards (pick one for BOARD_ID).
#   4. Set runtime env vars below in Hostinger and redeploy.
#
# Access tokens expire in ~30 days; refresh tokens in ~1 year. Re-run the
# auth script (or exchange the refresh token) before expiry.
PINTEREST_API_BASE_URL=
# During Trial access, set to https://api-sandbox.pinterest.com to route
# through the sandbox. Leave empty (or unset) for Standard-access production.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_BOARD_ID=
# Optional: section ID within the board for category-specific pins.
PINTEREST_SECTION_ID=

# Admin endpoints (push broadcast, social auto-post, queue preview) require
# this key when set. If empty, those routes 404 in production.
ADMIN_KEY=
ADMIN_BEARER_TOKEN=
DATABASE_URL=
DATABASE_PRIMARY=sqlite
DUAL_WRITE_POSTGRES=false

# ── Queue / Redis foundation (Phase 1) ──────────────────────────────────
# Recommended production split:
#   web       → ENABLE_SCHEDULER=false USE_BULLMQ=true
#   scheduler → USE_BULLMQ=true
#   worker    → USE_BULLMQ=true
REDIS_URL=
BULLMQ_PREFIX=scoop
USE_BULLMQ=false
REQUIRE_REDIS=false
QUEUE_CONCURRENCY_INGESTION=1
QUEUE_CONCURRENCY_VIDEO=1
QUEUE_CONCURRENCY_ENRICHMENT=2

# ── Stock-photo backgrounds for branded cards (visual upgrade) ──────────
# Get a free key at pexels.com/api (200 reqs/hr, 20k/mo on free tier — far
# more than the auto-poster will ever consume). When set, the card renderer
# composites a tag-matched landscape photo behind the headline + branding
# for a "world-class news publisher" look on Facebook / IG / LinkedIn. When
# unset, cards fall back to the typographic-only design (still strong, just
# not photographic).
PEXELS_API_KEY=

# ── Reality Index — LLM providers (Phase 1+) ───────────────────────────
# Two tiers:
#   STANDARD — high-volume default for matching, sentiment, reranking.
#              Set via LLM_PROVIDER.
#   PREMIUM  — low-volume quality jobs (analyst briefs, Phase 4).
#              Set via LLM_PREMIUM_PROVIDER. Opt in per-call with
#              { tier: "premium" }. Falls back to standard if unconfigured.
#
# Generation providers:
#   cerebras    — Cerebras Cloud. 1M tokens/day free. World's fastest
#                 inference (~450 tok/s on Llama 3.3 70B). cloud.cerebras.ai
#   cloudflare  — Cloudflare Workers AI. 10k neurons/day free. Llama 3.3 70B.
#                 Edge network — very low latency. Also provides 768-dim
#                 embeddings (drop-in for sqlite-vec, no schema change).
#                 dash.cloudflare.com → Workers AI → API token.
#   nim         — NVIDIA Build (build.nvidia.com). ~1000 free credits/model.
#                 Best for premium tier (high quality, low volume).
#   groq        — Groq Cloud. ~30 RPM free. Fast Llama 3.1.
#   ollama      — Local Ollama. Unlimited but reliability ≈ host machine.
#   gemini      — Gemini Flash (legacy). 15 RPM free.
#
# Embedding providers (EMBED_PROVIDER):
#   cloudflare  — @cf/baai/bge-base-en-v1.5 — 768-dim, matches schema.
#   ollama      — nomic-embed-text — 768-dim, local, unlimited.
#   gemini      — Gemini Embedding API — 768-dim via outputDimensionality.
#
# RECOMMENDED PRODUCTION HYBRID (no local infra, works from Pakistan):
#   LLM_PROVIDER=cerebras           (Llama 3.3 70B, 1M tok/day — all crons)
#   LLM_PREMIUM_PROVIDER=groq       (Llama 3.3 70B Versatile — globally accessible)
#   EMBED_PROVIDER=cloudflare       (768-dim bge-base-en-v1.5, 10k/day free)
#
# Note: NVIDIA NIM is geo-restricted in Pakistan. Groq is the premium alternative —
# it has Llama 3.3 70B Versatile (comparable quality) and is accessible globally.
LLM_PROVIDER=cerebras
LLM_PREMIUM_PROVIDER=groq
EMBED_PROVIDER=cloudflare

# Cerebras (cloud.cerebras.ai) ──────────────────────────────────────────
# Sign up at cloud.cerebras.ai → API Keys → "Create New API Key"
# Pick model: llama-3.3-70b (best quality, default), llama3.1-8b (faster).
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b
# CEREBRAS_RPM=30

# Cloudflare Workers AI ─────────────────────────────────────────────────
# Step-by-step setup:
#   1. Create a free account at cloudflare.com (no credit card needed).
#   2. Log in → look at the right sidebar of the dashboard home page.
#      You'll see "Account ID" — it's a 32-char hex string. Copy it.
#   3. Go to: dash.cloudflare.com/profile/api-tokens
#   4. Click "Create Token" → select "Workers AI" template (pre-built).
#   5. Name it (e.g. "scoopfeeds"), leave permissions as-is → "Create Token".
#   6. Copy the token shown (displayed only once). Paste below.
# Note: no website/domain needed — just a free Cloudflare account.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_GEN_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
CLOUDFLARE_EMBED_MODEL=@cf/baai/bge-base-en-v1.5
# CLOUDFLARE_RPM=60

# NVIDIA NIM (build.nvidia.com) ─────────────────────────────────────────
# Premium-tier default. Get key: build.nvidia.com → "Get API Key".
# Strong picks: meta/llama-3.3-70b-instruct (default — GPT-4-class JSON),
#               nvidia/llama-3.3-nemotron-super-49b-v1 (reasoning),
#               qwen/qwen3-5-122b-a10b (top open reasoning).
NVIDIA_API_KEY=
NIM_MODEL=meta/llama-3.3-70b-instruct
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM_RPM=10

# Groq (console.groq.com) ───────────────────────────────────────────────
# Sign up at console.groq.com → "API Keys" → "Create API Key". Free tier.
# Used as the premium tier (globally accessible; works from Pakistan).
# llama-3.3-70b-versatile = GPT-4-class quality for analyst briefs.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_RPM=25

# Ollama (local, optional fallback) ─────────────────────────────────────
# Only needed if LLM_PROVIDER=ollama or EMBED_PROVIDER=ollama.
# 16GB Mac sweet spot: llama3.1:8b. ollama pull llama3.1:8b nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Gemini (legacy) ───────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_RPM=15

# Single-knob RPM override for the active standard-tier provider.
# LLM_RPM=

# Set to 1 to disable all LLM calls (Reality Index still loads; matching is skipped).
# LLM_DISABLED=0

# Feature flag — set to false to disable Reality Index crons entirely.
ENABLE_REALITY_INDEX=true

# === Reality Index Phase 3 — Sentiment, social ingesters, anomalies ===

# Per-source feature flags. Default ON for the four core sources; X / Threads
# stay OFF until upstream stability is proven (per plan §1C).
# ENABLE_SOCIAL_BLUESKY=true
# ENABLE_SOCIAL_REDDIT=true
# ENABLE_SOCIAL_MASTODON=true
# ENABLE_SOCIAL_HN=true
# ENABLE_TREND_WIKIPEDIA=true
# ENABLE_SOCIAL_X=false
# ENABLE_SOCIAL_THREADS=false

# Mastodon instance to query (any public instance with /api/v2/search).
# MASTODON_INSTANCE=https://mastodon.social

# Reality Index composite weights (must roughly sum to 1.0).
# RI_W_MARKET=0.5
# RI_W_MEDIA=0.2
# RI_W_SOCIAL=0.2
# RI_W_ECONOMIC=0.1

# Sentiment cycle bound — number of active events scored per cron tick.
# RI_SENTIMENT_EVENTS_PER_CYCLE=20

# Anomaly thresholds.
# ANOMALY_ODDS_SHIFT_PP=10        # market YES delta in window (percentage points)
# ANOMALY_TG_SPIKE=0.30           # |truth_gap| jump in window
# ANOMALY_VIRAL_RATIO=3.0         # social volume vs 24h baseline
# ANOMALY_SENT_FLIP_MIN=0.30      # min |polarity| each side of a flip

# Watchlist push fan-out (Phase 4c). Default: scan last 30 min.
# WATCHLIST_PUSH_LOOKBACK_MS=1800000

# Reel topic selector (Phase 4e). Set to 1 to use the RI-aware ranker for
# the short-form video gen cron — prioritises articles bound to events
# with fresh anomalies / large truth-gap. Off by default (uses credibility).
# REEL_USE_RI_SELECTOR=0

# === Phase 5 — GDELT global news multiplier ===
#
# GDELT 2.0 indexes thousands of outlets in 65 languages every 15 min.
# When enabled, the gdeltFetcher cron (every 30 min) pulls fresh
# English-language articles by topic and inserts them as `articles` rows.
# They flow through the same cluster→event→matcher pipeline as RSS.
# ENABLE_GDELT=true                   # set to false to disable the cron
# GDELT_MAX_PER_TOPIC=30              # articles per topic per cycle
# GDELT_TIMESPAN=30min                # how far back per pull ("15min", "1h", etc.)
# GDELT_TOPICS=...                    # comma-separated "category:query" pairs
                                       # (overrides the default topic list)

# ─────────────────────────────────────────────────────────────────────────────
# EVENT GRAPH, DOSSIER & FACETS
#
# Full table with prod values + runtime-flip safety:
#   docs/reference/env_reference.md
# All values below are the CODE DEFAULTS. Prod sets only a handful (marked ★);
# everything else runs on these defaults.
# ─────────────────────────────────────────────────────────────────────────────

# --- Matcher / promoter ---
# Wave 2 unified affinity is now the ONLY path (EVENT_UNIFIED_AFFINITY retired 2026-07-20 —
# the legacy branches were dead with the flag on; keeping the flag was a footgun).
# EVENT_MIN_ARTICLES=5                 # cluster size (or >=1 bound market) required to promote
# EVENT_MATCH_TAU=0.78                 # cluster<->event centroid-cosine floor
# EVENT_MERGE_TAU=0.86                 # event<->event cosine floor confirming a merge
# EVENT_ENTITY_MIN=0                   # ★prod 0.05. Legacy entity gate; 0 = off
# EVENT_ENTITY_TOPK=40                 # top-K rarest entity keys per set
# EVENT_ENTITY_CORE_FRAC=0.3           # key must span this fraction of members to be "core"
# EVENT_ENTITY_MAX_CATSPAN=3           # hub filter for the live matcher (storyAffinity)
# EVENT_SIGNATURE_MAX_CATSPAN=999      # hub filter for the durable signature/chaining path ONLY
#                                      #   (999 = no filter; deliberately separate — see architecture doc)
# EVENT_PROMOTE_MAX_CLUSTER_AGE_MS=172800000   # 48h; only fresh clusters may spawn NEW events
# EVENT_CLOSE_ENABLED=false            # ★prod true. R2a: dormant events eventually close
# EVENT_CLOSE_AFTER_MS=1814400000      # 21d inactivity before close

# --- Affinity bands (storyAffinity.js) ---
# AFFINITY_T_MATCH=0.23                # >= this  => AFFINE (attach/merge allowed)
# AFFINITY_T_DISJOINT=0.19             # <  this  => FOREIGN (split allowed); between = AMBIGUOUS, all hold
# AFFINITY_MIN_CORE_KEYS=2             # coherence contract: min core keys
# AFFINITY_MIN_CORE_IDF=4              # coherence contract: min core idf mass
# AFFINITY_NEWBORN_MAX_MEMBERS=8       # newborn exemption from incoherence (R1)
# AFFINITY_NEWBORN_MAX_AGE_MS=86400000 # 24h newborn exemption

# --- W2.1 merge floor: SHIPPED DISABLED. Do not enable without recalibration. ---
# Labeled SAME pairs span ent 0.248-0.377, entirely BELOW 0.50, so the ent condition is
# always-true and the floor collapses to "block every thin-sided merge" (incl. the R1
# newborn continuation). Recalibrate on the decision-time (ent, min-side) data the
# 🧭 promoter-merge line now logs. See docs/reference/env_reference.md.
# EVENT_MERGE_FLOOR_MIN_SIDE=0         # 0 = disabled (no-op)
# EVENT_MERGE_FLOOR_ENT=0.50           # ent below which the thin-side block applies

# --- Breaker + A5 facets ---
# EVENT_BREAKER_ENABLED=false          # ★prod true. Splits foreign sub-clusters out of an event
# EVENT_BREAKER_MIN_ARTICLES=6         # min members to be a breaker candidate
# EVENT_BREAKER_DISJOINT=0.06          # legacy (non-unified) split threshold
# EVENT_BREAKER_DETACH=false           # ★prod true. Trim un-clusterable orphan tails
# EVENT_BREAKER_MAX_PASSES=6           # sweep convergence bound
# EVENT_FACETS_PERSIST=false           # ★prod true. Persist render-ready facets (event_facets)
# EVENT_FACET_TAU=0.88                 # PRESENTATION-ONLY facet sub-clustering tau (breaker split stays 0.78)
# FACET_MIN_ARTICLES=5                 # earn-render: min articles per facet
# FACET_MAX_SHARE=0.5                  # a facet larger than this share of the event is a pseudo-event
# FACET_DEDUP_OVMIN=0.5                # member overlap-over-min dedup (NOT Jaccard: tombstone dups are nested)

# --- Storylines (R2b) ---
# STORYLINE_ENABLED=false              # ★prod true. Chains episodes; feeds dossier ANGLES
# STORYLINE_MIN=0.25                   # weighted-Jaccard floor
# STORYLINE_MIN_SHARED_IDF=10          # rare-evidence floor (>=2 shared keys w/ this idf mass)
# STORYLINE_LOOKBACK_MS=7776000000     # 90d

# --- A6 dossier timeline (occurrence log) ---
# EVENT_TL_DEDUP_TAU=0.88              # near-dup cosine for grouping articles into one occurrence
# EVENT_TL_DEDUP_WINDOW_H=6            # LOAD-BEARING span cap. Without it, beats chain across days
# EVENT_TL_MIN_DEDUP=4                 # below this article count, dedup is a no-op (thin-event guard)
# EVENT_TIMELINE_MAX_EVENTS=2000       # event_timeline writer window (was a hardcoded 500 -> starvation)

# --- LLM cost rails (gate (a)) ---
# GEMINI_GENERATION_MODEL=gemini-2.5-flash   # ★prod gemini-3.1-flash-lite
# LLM_DAILY_CALL_CAP=2000              # hard daily ceiling on LLM calls
# LLM_DISABLED= / GEMINI_DISABLED=     # kill switches; deterministic fallbacks take over
# ENTITY_EXTRACTION_ENABLED=false      # ★prod set. Entity extraction feeding the affinity measure
# ENTITY_EXTRACTION_BATCH=100          # ★prod set
# ENTITY_IDF_ENABLED=false             # rolling entity-IDF window (all rarity weighting depends on it)
# ENTITY_IDF_WINDOW_MS=2592000000      # 30d

# --- Frontend (build-time; requires a rebuild) ---
# VITE_SENTIMENT_ENABLED=false         # sentiment module hidden (comprehensibility, not data sufficiency)
