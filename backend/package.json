{
  "name": "news-aggregator-backend",
  "version": "1.0.0",
  "description": "Apple News-style aggregator backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:web": "ENABLE_SCHEDULER=false node server.js",
    "start:scheduler": "node src/jobs/schedulerProcess.js",
    "start:worker": "node src/jobs/workerProcess.js",
    "dev": "nodemon server.js",
    "dev:web": "ENABLE_SCHEDULER=false nodemon server.js",
    "dev:scheduler": "nodemon src/jobs/schedulerProcess.js",
    "dev:worker": "nodemon src/jobs/workerProcess.js",
    "test:admin-auth": "node scripts/test-admin-auth.mjs",
    "db:backup": "node scripts/db-backup.mjs",
    "db:migrate": "node src/db/migrate.js"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@mozilla/readability": "^0.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "axios": "^1.6.7",
    "better-sqlite3": "^11.10.0",
    "bullmq": "^5.76.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsdom": "^29.0.2",
    "linkedom": "^0.18.12",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "rss-parser": "^3.13.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "slugify": "^1.6.6",
    "sqlite-vec": "^0.1.9",
    "stripe": "^16.0.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "overrides": {
    "html-encoding-sniffer": "^3.0.0"
  }
}
